# Copy this file to `.env` and fill in your values.

# --- LLM provider selection ---
# Which provider the RAG pipeline uses for answer generation.
# Options: groq | openai | ollama | hf_local  (pluggable; see src/llm.py)
#   hf_local = run our fine-tuned model (base + LoRA adapter) in-process.
LLM_PROVIDER=groq

# Model name for the selected provider.
#   groq   e.g. llama-3.3-70b-versatile
#   openai e.g. gpt-4o-mini
#   ollama e.g. llama3.1
LLM_MODEL=llama-3.3-70b-versatile

# --- API keys (only the one for your chosen provider is needed) ---
# Get a free Groq key at https://console.groq.com/keys
GROQ_API_KEY=
# OPENAI_API_KEY=
# For OpenAI-compatible endpoints (e.g. local servers), optionally override:
# OPENAI_BASE_URL=

# --- Embeddings (local, open-source) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- Retrieval / confidence settings ---
TOP_K=4
# Preferred fallback gate: sigmoid(top cross-encoder score). Below this the bot
# says "I don't know" instead of answering. 0.5 == a neutral cross-encoder score.
MIN_CONFIDENCE=0.5
# Backup gate on bi-encoder cosine, used ONLY when RERANK_ENABLED=false.
# (multilingual-e5 cosines are compressed — even unrelated text scores ~0.75 —
#  so this is a weak signal; the cross-encoder confidence above is preferred.)
MIN_SCORE=0.70

# --- Re-ranking (cross-encoder) ---
# Fetch RERANK_CANDIDATES chunks by cosine, then re-score them jointly with the
# query using a cross-encoder and keep the best TOP_K. Set false to disable
# (e.g. to compare retrieval quality with/without re-ranking).
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANK_CANDIDATES=20

# --- Diagnostics ---
# During ingest, also write human-readable cleaned text per document to
# data/processed/text/ (a deliverable + debugging aid; not used by retrieval).
# Set to false to skip.
WRITE_PROCESSED_TEXT=true
